Protocol: PhotoFolderDelegation_Typed

Types:
    Agent A,B,P,idp;
    Data photoFolder;
    Number NB,NP;
    Function photos,pw;
    Format fAskP, fPNonce, fAskB, fBNonce, fDelReq, fDelTok, fDeliver;

Knowledge:
    A:   A,B,P,idp,pk(idp),photoFolder,pw(A);
    P:   A,B,P,idp,pk(P),pk(idp),inv(pk(P));
    B:   A,B,P,idp,pk(B),pk(P),pk(idp),inv(pk(B)),photos(A);
    idp: A,B,P,idp,pk(B),pk(P),pk(idp),inv(pk(idp)),pw(A);

where A!=B, A!=P, A!=idp, B!=P, B!=idp, P!=idp

Actions:

# A asks P for a fresh nonce
A   ->  P   : fAskP(A,B)

# P responds with challenge nonce
P   ->  A   : fPNonce(NP)

# A initiates by telling B she wants to delegate to P
A   ->  B   : fAskB(A,P)

# B sends challenge nonce
B   ->  A   : fBNonce(NB)

# A requests delegation from idp with both nonces
A   ->  idp : {fDelReq(A,P,B,photoFolder,pw(A),NB,NP)}pk(idp)

# idp issues signed delegation token, encrypted for B
idp ->  A   : {{fDelTok(A,P,B,photoFolder,NB,NP)}inv(pk(idp))}pk(B)

# A forwards token to B
A   ->  B   : {{fDelTok(A,P,B,photoFolder,NB,NP)}inv(pk(idp))}pk(B)

# B sends token + photos to P
B   ->  P   : {fDeliver({fDelTok(A,P,B,photoFolder,NB,NP)}inv(pk(idp)), photos(A))}pk(P)

Goals:
    B authenticates idp on A,P,B,photoFolder,NB,NP
    P authenticates idp on A,P,B,photoFolder,NB,NP